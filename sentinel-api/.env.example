# =============================================================================
# Sentinel API — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# Application environment: development | production
APP_ENV=development

# Enable debug mode (verbose logging, docs endpoint)
DEBUG=false

# Secret key for JWT signing — MUST be changed in production
SECRET_KEY=change-me-in-production

# SQLite database path (stored on Docker volume at /data)
DATABASE_URL=sqlite+aiosqlite:///data/sentinel.db

# Redis connection (used for future caching / pub-sub)
REDIS_URL=redis://sentinel-redis:6379/0

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# Managed PostgreSQL admin connection (for database admin features)
PG_ADMIN_HOST=
PG_ADMIN_PORT=25060
PG_ADMIN_USER=
PG_ADMIN_PASSWORD=
PG_ADMIN_DATABASE=defaultdb
PG_ADMIN_SSLMODE=require

# Fernet encryption key for storing sensitive env vars
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Default admin user created on first boot
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=
