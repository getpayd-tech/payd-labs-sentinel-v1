# =============================================================================
# Sentinel Self-Host - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values, then run:
#   docker network create proxy
#   docker compose -f docker-compose.selfhost.yml up -d
# =============================================================================

# --- Core ---------------------------------------------------------------------
APP_ENV=production
DEBUG=false

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Fernet key for encrypting env vars stored in Sentinel's DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Internal services --------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:////data/sentinel.db
REDIS_URL=redis://sentinel-redis:6379/0

# --- This Sentinel instance (MUST be set before first boot) -------------------
# Public URL of this Sentinel deployment. Used in generated CI/CD workflows
# and wherever the UI references "this server".
SENTINEL_URL=https://sentinel.yourteam.com

# Comma-separated CORS origins. Usually just the Sentinel URL.
CORS_ORIGINS=https://sentinel.yourteam.com

# Informational server IP shown in DNS instructions for custom domains.
SERVER_IP=

# --- Docker -------------------------------------------------------------------
# Caddy reverse-proxy container name (must match container_name in compose).
CADDY_CONTAINER=caddy-proxy

# External Docker network that Caddy + deployed services share.
PROXY_NETWORK=proxy

# On-demand TLS catch-all upstream. Blank = no catch-all (unregistered custom
# domains will 404 from Caddy). Set to "host:port" to route unregistered
# domains to a fallback service.
CATCHALL_UPSTREAM=

# --- Auth (Payd Auth) ---------------------------------------------------------
# Required for login. Sentinel uses Payd Auth as its SSO provider.
PAYD_AUTH_URL=https://auth.payd.money
PAYD_API_URL=https://api.payd.money/v1

# Comma-separated Payd Auth usernames allowed to log in. Blank = any admin.
ALLOWED_USERNAMES=

# --- GHCR (for pulling private images during deploys) -------------------------
GHCR_USER=your-github-org
# PAT with read:packages scope. Only needed if your deployed projects use
# private GHCR images. Generate at github.com/settings/tokens.
GHCR_TOKEN=

# --- Optional: Managed PostgreSQL (for the database browser feature) ----------
# Leave blank to disable the database browser page.
PG_ADMIN_HOST=
PG_ADMIN_PORT=5432
PG_ADMIN_USER=
PG_ADMIN_PASSWORD=
PG_ADMIN_DATABASE=defaultdb
PG_ADMIN_SSLMODE=require

# --- JWT config ---------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
